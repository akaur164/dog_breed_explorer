<!DOCTYPE html>
<html>
  <head>
    <title>Dog Breed Explorer</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  </head>

  <body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
      <div class="container">
        <%= link_to "Dog Breed Explorer", root_path, class: "navbar-brand" %>

        <div class="navbar-nav">
          <%= link_to "Home", root_path, class: "nav-link" %>
          <%= link_to "Breeds", breeds_path, class: "nav-link" %>
          <%= link_to "Groups", groups_path, class: "nav-link" %>
          <%= link_to "Temperaments", temperaments_path, class: "nav-link" %>
          <%= link_to "About", about_path, class: "nav-link" %>
        </div>
      </div>
    </nav>

    <main class="container mb-5">
      <%= yield %>
    </main>
  </body>
</html>