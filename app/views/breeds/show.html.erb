<div class="card shadow-sm mb-4">
  <div class="card-body">
    <h1 class="card-title"><%= @breed.name %></h1>

    <p>
      <strong>Group:</strong>
      <%= link_to @breed.group.name, group_path(@breed.group) %>
    </p>

    <p><strong>Description:</strong></p>
    <p><%= @breed.description %></p>

    <div class="row">
      <div class="col-md-4">
        <p><strong>Height:</strong><br>
        <%= @breed.min_height %> - <%= @breed.max_height %> inches</p>
      </div>

      <div class="col-md-4">
        <p><strong>Weight:</strong><br>
        <%= @breed.min_weight %> - <%= @breed.max_weight %> lbs</p>
      </div>

      <div class="col-md-4">
        <p><strong>Life Expectancy:</strong><br>
        <%= @breed.min_expectancy %> - <%= @breed.max_expectancy %> years</p>
      </div>
    </div>
  </div>
</div>

<div class="card shadow-sm mb-4">
  <div class="card-body">
    <h2>Temperaments</h2>

    <% if @breed.temperaments.any? %>
      <% @breed.temperaments.each do |temperament| %>
        <%= link_to temperament.name, temperament_path(temperament), class: "badge bg-primary text-decoration-none me-1" %>
      <% end %>
    <% else %>
      <p>No temperament data available.</p>
    <% end %>
  </div>
</div>

<div class="card shadow-sm mb-4">
  <div class="card-body">
    <h2>Reviews</h2>

    <% @breed.reviews.each do |review| %>
      <div class="border-bottom mb-3 pb-3">
        <strong><%= review.reviewer_name %></strong>
        <span class="text-warning">★</span> <%= review.rating %>/5
        <p><%= review.comment %></p>
      </div>
    <% end %>
  </div>
</div>

<%= link_to "Back to Breeds", breeds_path, class: "btn btn-secondary" %>