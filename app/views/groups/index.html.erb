<div class="card shadow-sm">
  <div class="card-body">

    <h1 class="mb-4">Dog Groups</h1>

    <div class="list-group">
      <% @groups.each do |group| %>
        <%= link_to group_path(group), class: "list-group-item list-group-item-action d-flex justify-content-between align-items-center" do %>
          <span><%= group.name %></span>
          <span class="badge bg-primary rounded-pill">
            <%= group.breeds.count %> breeds
          </span>
        <% end %>
      <% end %>
    </div>

  </div>
</div>