<div class="card shadow-sm">
  <div class="card-body">
    <h1 class="mb-4">Temperaments</h1>

    <div class="list-group">
      <% @temperaments.each do |temperament| %>
        <%= link_to temperament_path(temperament), class: "list-group-item list-group-item-action d-flex justify-content-between align-items-center" do %>
          <span><%= temperament.name %></span>
          <span class="badge bg-primary rounded-pill">
            <%= temperament.breeds.count %> breeds
          </span>
        <% end %>
      <% end %>
    </div>
  </div>
</div>